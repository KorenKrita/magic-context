{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "noEmit": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "types": ["bun-types"],
        "paths": {
            "@magic-context/core/*": ["../plugin/src/*"]
        }
    },
    "include": ["src/**/*.ts", "tests/**/*.ts"]
}
